local b3 = makeBox(160, 50)
local plbl = Instance.new("TextLabel")
plbl.Size = UDim2.new(1, -80, 1, 0); plbl.Position = UDim2.new(0, 40, 0, 0)
plbl.BackgroundTransparency = 1; plbl.Text = "Self Viewing"
plbl.TextColor3 = Color3.fromRGB(255, 255, 255)
plbl.Font = Enum.Font.SourceSansBold; plbl.Parent = b3

local idx = 0; local targetPlayer = LP
local function getList()
    local t = {}
    for _, p in ipairs(game.Players:GetPlayers()) do if p ~= LP then table.insert(t, p) end end
    return t
end

local function target()
    local l = getList()
    if idx == 0 or #l == 0 then
        idx = 0; targetPlayer = LP; plbl.Text = "Self Viewing"
    else
        if idx > #l then idx = 1 elseif idx < 1 then idx = #l end
        targetPlayer = l[idx]
        plbl.Text = "Viewing: " .. targetPlayer.DisplayName
    end
end

local function arrow(txt, x, d)
    local a = Instance.new("TextButton")
    a.Size = UDim2.new(0, 30, 0, 30); a.Position = UDim2.new(0, x, 0, 10)
    a.BackgroundColor3 = Color3.fromRGB(45, 45, 45); a.Text = txt
    a.TextColor3 = Color3.fromRGB(0, 170, 255); a.Parent = b3
    a.MouseButton1Click:Connect(function() idx = idx + d; target() end)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 4); c.Parent = a
end
arrow("<", 5, -1); arrow(">", 215, 1)

