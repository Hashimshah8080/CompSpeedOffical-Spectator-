RS.RenderStepped:Connect(function()
    local t = targetPlayer or LP
    if t and t.Character then
        local hum = t.Character:FindFirstChildOfClass("Humanoid")
        local root = t.Character:FindFirstChild("HumanoidRootPart")
        local head = t.Character:FindFirstChild("Head")
        
        if hum and root and head then
            if mode == "1st" then
                Cam.CameraType = Enum.CameraType.Scriptable
                Cam.CFrame = head.CFrame * CFrame.new(0, 0, -0.1)
            elseif mode == "2nd" then
                Cam.CameraType = Enum.CameraType.Scriptable
                local faceOffset = root.CFrame * CFrame.new(0, 1.5, -5)
                Cam.CFrame = CFrame.new(faceOffset.Position, head.Position)
            elseif mode == "3rd" then
                Cam.CameraType = Enum.CameraType.Custom
                Cam.CameraSubject = hum
            end
            return
        end
    end
    Cam.CameraType = Enum.CameraType.Custom
    if LP.Character then Cam.CameraSubject = LP.Character:FindFirstChildOfClass("Humanoid") end
end)
