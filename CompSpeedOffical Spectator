-- Core System Logic
local activeMode = "3rd Person"
local targetPlayer = nil
local playerList = {}
local playerIndex = 0  -- 0 means watching yourself
local cameraConnection = nil

local function updateCamera()
    if not targetPlayer or not targetPlayer.Character then return end
    local head = targetPlayer.Character:FindFirstChild("Head")
    local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not head or not root then return end
    
    Camera.CameraType = Enum.CameraType.Scriptable
    if activeMode == "1st Person" then
        Camera.CFrame = head.CFrame * CFrame.new(0, 0, -0.2)
    elseif activeMode == "2nd Person" then
        Camera.CFrame = CFrame.new((root.CFrame * CFrame.new(0, 1.5, -7)).Position, head.Position)
    elseif activeMode == "3rd Person" then
        Camera.CFrame = CFrame.new((root.CFrame * CFrame.new(0, 3, 8)).Position, head.Position)
    end
end

local function startSpectate(player)
    if cameraConnection then cameraConnection:Disconnect() cameraConnection = nil end
    if not player or player == LocalPlayer then
        targetPlayer = nil
        playerIndex = 0
        DisplayLabel.Text = "Spectate: Myself"
        Camera.CameraType = Enum.CameraType.Custom
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            Camera.CameraSubject = LocalPlayer.Character.Humanoid
        end
        return
    end
    targetPlayer = player
    DisplayLabel.Text = "Spectate: " .. player.Name
    cameraConnection = RunService.RenderStepped:Connect(updateCamera)
end

local function rebuildList()
    playerList = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then table.insert(playerList, p) end
    end
end

-- Arrow Clicks (Fixed First-Tap Delay)
RightArrow.MouseButton1Click:Connect(function()
    rebuildList()
    if #playerList == 0 then startSpectate(nil) return end
    
    playerIndex = playerIndex + 1
    if playerIndex > #playerList then 
        startSpectate(nil) 
    else 
        startSpectate(playerList[playerIndex]) 
    end
end)

LeftArrow.MouseButton1Click:Connect(function()
    rebuildList()
    if #playerList == 0 then startSpectate(nil) return end
    
    playerIndex = playerIndex - 1
    if playerIndex < 0 then 
        playerIndex = #playerList 
        startSpectate(playerList[playerIndex]) 
    elseif playerIndex == 0 then 
        startSpectate(nil) 
    else 
        startSpectate(playerList[playerIndex]) 
    end
end)

btn1st.MouseButton1Click:Connect(function() activeMode = "1st Person" end)
btn2nd.MouseButton1Click:Connect(function() activeMode = "2nd Person" end)
btn3rd.MouseButton1Click:Connect(function() activeMode = "3rd Person" end)
