lbl.Size = UDim2.new(1, 0, 0, 40)
lbl.BackgroundTransparency = 1; lbl.Text = "-00:10"
lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
lbl.TextSize = 28; lbl.Font = Enum.Font.SourceSansBold; lbl.Parent = b2

local secs = -10; local running = false
local function update()
    local abs = math.abs(secs)
    lbl.Text = string.format("%s%02d:%02d", secs < 0 and "-" or "", math.floor(abs/60), abs%60)
end

task.spawn(function()
    while true do
        task.wait(1)
        if running and secs < 180 then
            secs = secs + 1; update()
            if secs >= 180 then running = false; lbl.TextColor3 = Color3.fromRGB(0, 255, 127) end
        end
    end
end)

