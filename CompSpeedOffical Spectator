local currentTime = -10
local timerRunning = false

local function updateTimerDisplay()
    local sign = currentTime < 0 and "-" or ""
    local absSec = math.abs(currentTime)
    TimerLabel.Text = string.format("%s%02d:%02d", sign, math.floor(absSec/60), absSec%60)
end

StartStopBtn.MouseButton1Click:Connect(function()
    timerRunning = not timerRunning
    StartStopBtn.Text = timerRunning and "STOP" or "START"
    StartStopBtn.BackgroundColor3 = timerRunning and Color3.fromRGB(180, 40, 40) or Color3.fromRGB(0, 150, 70)
    
    if timerRunning then
        task.spawn(function()
            while timerRunning do
                task.wait(1)
                if not timerRunning then break end
                currentTime = currentTime + 1
                if currentTime >= 180 then currentTime = 180 timerRunning = false StartStopBtn.Text = "START" StartStopBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 70) end
                updateTimerDisplay()
            end
        end)
    end
end)

ResetBtn.MouseButton1Click:Connect(function()
    timerRunning = false
    currentTime = -10
    StartStopBtn.Text = "START"
    StartStopBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 70)
    updateTimerDisplay()
end)

