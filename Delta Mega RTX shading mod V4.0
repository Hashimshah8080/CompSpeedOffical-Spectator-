end)

-- 12. Pastel Dream Filter
createOption("Pastel Dream Filter", Color3.fromRGB(230, 130, 180), function()
    clearEffects()
    local cc = Instance.new("ColorCorrectionEffect", Lighting)
    cc.Saturation = 0.3
    cc.Contrast = -0.05
    cc.TintColor = Color3.fromRGB(255, 220, 240)
end)

-- 13. High Contrast Sharpness
createOption("Ultra High Contrast", Color3.fromRGB(70, 70, 100), function()
    local cc = Lighting:FindFirstChildOfClass("ColorCorrectionEffect") or Instance.new("ColorCorrectionEffect", Lighting)
    cc.Contrast = 0.5
end)

-- 14. Mobile FPS Boost
createOption("⚡ Mobile FPS Boost", Color3.fromRGB(180, 130, 0), function()
    clearEffects()
    Lighting.GlobalShadows = false
    Lighting.EnvironmentDiffuseScale = 0
    Lighting.EnvironmentSpecularScale = 0
end)

-- 15. Complete Reset
createOption("❌ Reset Graphics", Color3.fromRGB(130, 0, 0), function()
    clearEffects()
    Lighting.ClockTime = 14
    Lighting.Brightness = 2
    Lighting.ExposureCompensation = 0
    Lighting.EnvironmentDiffuseScale = 0
    Lighting.EnvironmentSpecularScale = 0
    Lighting.GlobalShadows = true
    for _, part in pairs(workspace:GetDescendants()) do
        if part:IsA("BasePart") and part:FindFirstChildOfClass("Highlight") then
            part.Material = Enum.Material.Plastic
            part.Transparency = 0
            part.Reflectance = 0
            part:FindFirstChildOfClass("Highlight"):Destroy()
        end
    end
end)
